\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Per-card NoC injection over time for capacity-balanced BestFit (16 cards, bursty, uncapped). The busiest card (red) sits above the workload's own p75 bandwidth cap (dashed) in $\sim $98\,\% of steady-state ticks, while the cluster mean (blue) stays far below it: even-by-core-count packing leaves individual cards chronically saturated. The shaded area is demand the cap would have to queue.}}{4}{figure.1}\protected@file@percent }
\newlabel{fig:motivation_ts}{{1}{4}{Per-card NoC injection over time for capacity-balanced BestFit (16 cards, bursty, uncapped). The busiest card (red) sits above the workload's own p75 bandwidth cap (dashed) in $\sim $98\,\% of steady-state ticks, while the cluster mean (blue) stays far below it: even-by-core-count packing leaves individual cards chronically saturated. The shaded area is demand the cap would have to queue}{figure.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Worst-card-to-mean NoC pressure versus mean per-card utilisation (BestFit, 16 cards, bursty, 5 seeds). The busiest card runs $3$--$5\times $ the cluster mean across the whole range, and the ratio is \emph  {highest} at low utilisation ($4.9\times $ at 46\,\%): the pathology is not a symptom of overload but of temporal burst alignment, which capacity balance cannot see.}}{4}{figure.2}\protected@file@percent }
\newlabel{fig:motivation_util}{{2}{4}{Worst-card-to-mean NoC pressure versus mean per-card utilisation (BestFit, 16 cards, bursty, 5 seeds). The busiest card runs $3$--$5\times $ the cluster mean across the whole range, and the ratio is \emph {highest} at low utilisation ($4.9\times $ at 46\,\%): the pathology is not a symptom of overload but of temporal burst alignment, which capacity balance cannot see}{figure.2}{}}
