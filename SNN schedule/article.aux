\@writefile{toc}{\contentsline {paragraph}{The mean hides the saturation.}{8}{section*.8}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Worst-card-to-mean NoC pressure versus mean per-card utilisation (BestFit, 16 cards, bursty, 5 seeds). The busiest card runs $3$--$5\times $ the cluster mean across the whole range, and the ratio is \emph  {highest} at low utilisation ($4.9\times $ at 46\,\%): the pathology is not a symptom of overload but of temporal burst alignment, which capacity balance cannot see.}}{8}{figure.3}\protected@file@percent }
\newlabel{fig:motivation_util}{{3}{8}{Worst-card-to-mean NoC pressure versus mean per-card utilisation (BestFit, 16 cards, bursty, 5 seeds). The busiest card runs $3$--$5\times $ the cluster mean across the whole range, and the ratio is \emph {highest} at low utilisation ($4.9\times $ at 46\,\%): the pathology is not a symptom of overload but of temporal burst alignment, which capacity balance cannot see}{figure.3}{}}
