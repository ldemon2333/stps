\@writefile{toc}{\contentsline {paragraph}{Congestion falls in every cell.}{8}{section*.9}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces NoC congestion ratio normalised so the best baseline in each cell $=1.0$ (dashed line); 6 cells $=\{4,16\}$ cards $\times \{$Poisson, Bursty, Mixed$\}$, 5 schedulers each, 95\,\% CI. STPS is the only policy whose bar sits below the best-baseline line in \emph  {every} cell; the capacity baselines (RR, P2C) rise above it and even the two best baselines (BestFit/DRF) only tie the line they define. Consistency, not a single large margin, is the result.}}{9}{figure.4}\protected@file@percent }
\newlabel{fig:congestion_bars}{{4}{9}{NoC congestion ratio normalised so the best baseline in each cell $=1.0$ (dashed line); 6 cells $=\{4,16\}$ cards $\times \{$Poisson, Bursty, Mixed$\}$, 5 schedulers each, 95\,\% CI. STPS is the only policy whose bar sits below the best-baseline line in \emph {every} cell; the capacity baselines (RR, P2C) rise above it and even the two best baselines (BestFit/DRF) only tie the line they define. Consistency, not a single large margin, is the result}{figure.4}{}}
\@writefile{toc}{\contentsline {paragraph}{The relief is nearly free and does not cost dispersion.}{9}{section*.10}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{The small tail cost.}{9}{section*.11}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{The trade-off matches CIM contention.}{9}{section*.12}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces CDF of per-card time-mean NoC congestion over all 16 cards $\times $ 5 seeds, one panel per arrival. STPS's curve lies entirely to the left of every baseline: its whole per-card congestion distribution --- not merely the mean --- is stochastically lower, so \emph  {every} card, from least to most congested, runs cooler under STPS. BestFit and DRF coincide.}}{9}{figure.5}\protected@file@percent }
\newlabel{fig:percard_cdf}{{5}{9}{CDF of per-card time-mean NoC congestion over all 16 cards $\times $ 5 seeds, one panel per arrival. STPS's curve lies entirely to the left of every baseline: its whole per-card congestion distribution --- not merely the mean --- is stochastically lower, so \emph {every} card, from least to most congested, runs cooler under STPS. BestFit and DRF coincide}{figure.5}{}}
