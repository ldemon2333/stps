\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces Across-card load-balance metrics (16 cards, 5 seeds, averaged over Poisson/Bursty/Mixed; bold = best in column). CV/LIF/$t$CV/$t$LIF are lower-is-better, JFI higher-is-better. STPS leads every balance metric, and the CV margin is significant (non-overlapping 95\,\% intervals in all three arrivals). Load-aware P2C is the weakest balancer.}}{9}{table.3}\protected@file@percent }
\newlabel{tab:balance}{{3}{9}{Across-card load-balance metrics (16 cards, 5 seeds, averaged over Poisson/Bursty/Mixed; bold = best in column). CV/LIF/$t$CV/$t$LIF are lower-is-better, JFI higher-is-better. STPS leads every balance metric, and the CV margin is significant (non-overlapping 95\,\% intervals in all three arrivals). Load-aware P2C is the weakest balancer}{table.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces NoC congestion ratio normalised so the best baseline in each cell $=1.0$ (dashed line); 3 arrival modes $\times 16$ cards, 5 schedulers each, 95\,\% CI. STPS is the only policy whose bar sits below the best-baseline line in every cell; the capacity baselines (RR, P2C) rise above it.}}{9}{figure.4}\protected@file@percent }
\newlabel{fig:congestion_bars}{{4}{9}{NoC congestion ratio normalised so the best baseline in each cell $=1.0$ (dashed line); 3 arrival modes $\times 16$ cards, 5 schedulers each, 95\,\% CI. STPS is the only policy whose bar sits below the best-baseline line in every cell; the capacity baselines (RR, P2C) rise above it}{figure.4}{}}
\@writefile{toc}{\contentsline {paragraph}{Concurrent congestion relief.}{9}{section*.13}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces CDF of per-card time-mean NoC congestion over all 16 cards $\times $ 5 seeds, one panel per arrival. STPS's curve lies entirely to the left of every baseline: its whole per-card congestion distribution is stochastically lower, meaning the most congested cards run significantly cooler. BestFit and DRF coincide.}}{9}{figure.5}\protected@file@percent }
\newlabel{fig:percard_cdf}{{5}{9}{CDF of per-card time-mean NoC congestion over all 16 cards $\times $ 5 seeds, one panel per arrival. STPS's curve lies entirely to the left of every baseline: its whole per-card congestion distribution is stochastically lower, meaning the most congested cards run significantly cooler. BestFit and DRF coincide}{figure.5}{}}
\@writefile{toc}{\contentsline {paragraph}{Stage~A needs predictable fingerprints.}{9}{section*.14}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Utilisation determines whether topology matters.}{9}{section*.15}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Fingerprint composition does not make Stage~A a dispersion winner.}{9}{section*.16}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Stage~A under a utilisation sweep (16 cards, Poisson, mixed fingerprints, 5 seeds). Each point reports CV, so lower is better. Across the whole sweep BestFit/DRF hold the lowest CV because empty-capacity signals are the strongest placement cue; Stage~A tracks just above them (within $\sim $4--10\,\%) and stays ahead of RR and P2C. Dispersion falls monotonically as utilisation rises, but no policy --- Stage~A included --- reduces it below the capacity baselines: Stage~A is not a dispersion-minimising placement.}}{10}{figure.6}\protected@file@percent }
\newlabel{fig:q1_util}{{6}{10}{Stage~A under a utilisation sweep (16 cards, Poisson, mixed fingerprints, 5 seeds). Each point reports CV, so lower is better. Across the whole sweep BestFit/DRF hold the lowest CV because empty-capacity signals are the strongest placement cue; Stage~A tracks just above them (within $\sim $4--10\,\%) and stays ahead of RR and P2C. Dispersion falls monotonically as utilisation rises, but no policy --- Stage~A included --- reduces it below the capacity baselines: Stage~A is not a dispersion-minimising placement}{figure.6}{}}
\@writefile{toc}{\contentsline {paragraph}{Q1 takeaway.}{10}{section*.17}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {7.3}Q2: Macro-Dispatch and Phase-Shift Are Complementary}{10}{subsection.7.3}\protected@file@percent }
\newlabel{sec:eval:spatial}{{7.3}{10}{Q2: Macro-Dispatch and Phase-Shift Are Complementary}{subsection.7.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Stage~A under a fingerprint-composition sweep (16 cards, Poisson, 70\,\% utilisation). Each point reports CV, so lower is better; the x-axis gives the bursty share of a steady-flat/bursty mix. CV climbs with burstiness for every policy, because bursty fingerprints inject sharper per-card peaks that no placement can equalise. Stage~A tracks BestFit/DRF across the whole sweep --- tied at $0\,\%$ bursty and within the baseline band throughout --- so topology-aware placement neither wins nor loses dispersion as burstiness grows. RR happens to hold the lowest CV at the flat end; the fingerprint's value is congestion relief, not dispersion, which this sweep does not measure.}}{10}{figure.7}\protected@file@percent }
\newlabel{fig:q1_mix}{{7}{10}{Stage~A under a fingerprint-composition sweep (16 cards, Poisson, 70\,\% utilisation). Each point reports CV, so lower is better; the x-axis gives the bursty share of a steady-flat/bursty mix. CV climbs with burstiness for every policy, because bursty fingerprints inject sharper per-card peaks that no placement can equalise. Stage~A tracks BestFit/DRF across the whole sweep --- tied at $0\,\%$ bursty and within the baseline band throughout --- so topology-aware placement neither wins nor loses dispersion as burstiness grows. RR happens to hold the lowest CV at the flat end; the fingerprint's value is congestion relief, not dispersion, which this sweep does not measure}{figure.7}{}}
\@writefile{toc}{\contentsline {paragraph}{Phase-shift zeroes congestion but pays in throughput.}{10}{section*.18}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Incremental stage ablation at the default congested workpoint (16 cards, $BW_{\max }\!=\!9\!\times \!10^{5}$, $D_{\max }\!=\!2$, 3200 tasks). Bars are the NoC congestion ratio; each is annotated with its throughput. Phase-shift on a blind baseline (BestFit\,+ps) zeroes congestion only by paying $-24$--$30$\,\% throughput; macro-dispatch alone (STPS-A) preserves throughput but leaves congestion untouched; only the pairing (full STPS) relieves congestion \emph  {and} keeps throughput. Neither stage alone reaches the operating point.}}{11}{figure.8}\protected@file@percent }
\newlabel{fig:ablation}{{8}{11}{Incremental stage ablation at the default congested workpoint (16 cards, $BW_{\max }\!=\!9\!\times \!10^{5}$, $D_{\max }\!=\!2$, 3200 tasks). Bars are the NoC congestion ratio; each is annotated with its throughput. Phase-shift on a blind baseline (BestFit\,+ps) zeroes congestion only by paying $-24$--$30$\,\% throughput; macro-dispatch alone (STPS-A) preserves throughput but leaves congestion untouched; only the pairing (full STPS) relieves congestion \emph {and} keeps throughput. Neither stage alone reaches the operating point}{figure.8}{}}
\@writefile{toc}{\contentsline {paragraph}{Full STPS also protects load balance.}{11}{section*.19}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{The two stages occupy complementary roles.}{11}{section*.20}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces How each metric responds as the phase-shift budget $D_{\max }$ grows from 2 to 16 (16 cards, lightly-capped regime: $BW_{\max }\!=\!9\!\times \!10^{5}$, 1600 tasks, mixed fingerprints, 5 seeds). Congestion --- the metric STPS targets --- is a switch, not a knob: it is already zeroed for the capacity baselines at $D_{\max }\!=\!2$ and full STPS holds its residual $\sim $0.035 flat across the sweep. The dispersion diagnostics (CV/JFI/LIF) do improve with a larger budget in this loosely-capped regime, but with diminishing returns that saturate near $D_{\max }\!=\!8$, while the mean offset (and thus tail delay) grows monotonically. The columns pull in opposite directions, which is what fixes a small default.}}{11}{table.4}\protected@file@percent }
\newlabel{tab:q2_dmax}{{4}{11}{How each metric responds as the phase-shift budget $D_{\max }$ grows from 2 to 16 (16 cards, lightly-capped regime: $BW_{\max }\!=\!9\!\times \!10^{5}$, 1600 tasks, mixed fingerprints, 5 seeds). Congestion --- the metric STPS targets --- is a switch, not a knob: it is already zeroed for the capacity baselines at $D_{\max }\!=\!2$ and full STPS holds its residual $\sim $0.035 flat across the sweep. The dispersion diagnostics (CV/JFI/LIF) do improve with a larger budget in this loosely-capped regime, but with diminishing returns that saturate near $D_{\max }\!=\!8$, while the mean offset (and thus tail delay) grows monotonically. The columns pull in opposite directions, which is what fixes a small default}{table.4}{}}
