\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces End-to-end comparison on the mixed-fingerprint workload (5 seeds, mean values; bold = best in column). STPS is the \emph  {only} scheduler that wins on both congestion metrics in every $\{$arrival, scale$\}$ cell tested at a 1--2\tmspace  +\thinmuskip {.1667em}\% throughput cost. The advantage in the worst-card max/min ratio sharpens with scale: at 16 cards STPS holds it under $13.5\times $ while every baseline develops a $14$--$24\times $ skew.}}{8}{table.1}\protected@file@percent }
\newlabel{tab:q0_main}{{1}{8}{End-to-end comparison on the mixed-fingerprint workload (5 seeds, mean values; bold = best in column). STPS is the \emph {only} scheduler that wins on both congestion metrics in every $\{$arrival, scale$\}$ cell tested at a 1--2\,\% throughput cost. The advantage in the worst-card max/min ratio sharpens with scale: at 16 cards STPS holds it under $13.5\times $ while every baseline develops a $14$--$24\times $ skew}{table.1}{}}
\@writefile{toc}{\contentsline {paragraph}{The scale signal.}{8}{section*.10}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Is the trade favourable?}{8}{section*.11}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Throughput decomposition at 16 cards: cold-start-excluded throughput closes only $0.16$--$0.17$\tmspace  +\thinmuskip {.1667em}\% of the $0.6$--$1.4$\tmspace  +\thinmuskip {.1667em}\% gap to the best baseline. The remaining gap is contention-avoidance --- the price STPS pays to keep the NoC under its cap.}}{8}{table.2}\protected@file@percent }
\newlabel{tab:q0_cold}{{2}{8}{Throughput decomposition at 16 cards: cold-start-excluded throughput closes only $0.16$--$0.17$\,\% of the $0.6$--$1.4$\,\% gap to the best baseline. The remaining gap is contention-avoidance --- the price STPS pays to keep the NoC under its cap}{table.2}{}}
